# ─────────────────────────────────────────────────────────────
# Finance AX MVP — 환경변수 예시. 복사: cp .env.example .env
# ANTHROPIC_API_KEY는 절대 프론트엔드에 노출 금지 (모든 Claude 호출은 백엔드 경유)
# ─────────────────────────────────────────────────────────────

# --- API server ---
NODE_ENV=development
API_PORT=3000

# --- Database (Postgres) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/axaxax?schema=public"

# --- Auth ---
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="1d"

# --- Redis / BullMQ ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Anthropic (백엔드 전용) ---
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-8"
# 환각 가드: 리포트 재생성 최대 횟수
REPORT_MAX_REGEN=2

# --- Tenant (MVP는 단일 테넌트) ---
DEFAULT_TENANT_ID="DEFAULT"

# --- Web (Vite) ---
VITE_API_BASE_URL="http://localhost:3000"
