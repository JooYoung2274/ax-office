{
  "name": "axaxax",
  "version": "0.1.0",
  "private": true,
  "description": "AI 네이티브 AX 전환 웹 서비스 — Finance AX MVP",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:packages": "npm run build -w @axaxax/shared -w @axaxax/calc-engine -w @axaxax/report-engine",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run start:dev -w @axaxax/api",
    "dev:web": "npm run dev -w @axaxax/web",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
